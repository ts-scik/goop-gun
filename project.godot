; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="goop-gun"
run/main_scene="uid://dk1pnqsqbyrb2"
config/features=PackedStringArray("4.5", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

GameManager="*res://Scripts/Globals/game_manager.gd"

[debug_draw_3d]

settings/addon_root_folder="res://addons/debug_draw_3d"

[dotnet]

project/assembly_name="receiver-proto"

[file_customization]

folder_colors={
"res://Models/": "orange",
"res://Prefabs/": "purple",
"res://Prefabs/Unused/Rooms/": "green",
"res://Scripts/": "blue",
"res://Scripts/Unused/Level/": "green"
}

